{
    "name": "reactappts.client",
    "private": true,
    "version": "1.0.0",
    "description": "Table Configuration and Governance Tool",
    "type": "module",
    "main": "electron.cjs",
    "homepage": "./",
    "scripts": {
        "dev": "cross-env NODE_ENV=development concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
        "vite-dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "lint": "eslint .",
        "electron": "electron .",
        "dist": "npm run build && npm run electron-build",
        "electron-build": "electron-builder"
    },
    "dependencies": {
        "papaparse": "^5.5.3",
        "parquetjs-lite": "^0.8.7",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-router-dom": "^7.13.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@types/node": "^24.11.0",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.1",
        "concurrently": "^8.2.2",
        "cross-env": "^10.1.0",
        "electron": "^37.10.3",
        "electron-builder": "^26.8.1",
        "eslint": "^9.39.1",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.24",
        "globals": "^16.5.0",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.48.0",
        "vite": "^7.3.1",
        "wait-on": "^7.2.0"
    },
    "build": {
        "appId": "com.yourcompany.tableconfigurator",
        "productName": "Table Configurator",
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*",
            "electron.cjs",
            "node_modules/**/*",
            "package.json"
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "nsis": {
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true
        }
    }
}
